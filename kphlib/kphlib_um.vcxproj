  <!-- sistatus
    The message file is compiled per-configuration into
    bin\$(Configuration)$(PlatformArchitecture)\. The kernelmode side uses the
    WDK MessageCompile task; the usermode side uses a CustomBuild item that
    invokes the Windows SDK mc.exe with equivalent flags (no WDK requirement).
    The declared Outputs make incremental builds skip mc.exe when sistatus.mc
    is unchanged.
  -->
  <ItemGroup>
    <CustomBuild Include="sistatus.mc">
      <Command>if not exist "$(ProjectDir)bin\$(Configuration)$(PlatformArchitecture)" mkdir "$(ProjectDir)bin\$(Configuration)$(PlatformArchitecture)"
mc.exe -c -u -U -n -b -h "$(ProjectDir)bin\$(Configuration)$(PlatformArchitecture)" -r "$(ProjectDir)bin\$(Configuration)$(PlatformArchitecture)" "%(FullPath)"</Command>
      <Outputs>$(ProjectDir)bin\$(Configuration)$(PlatformArchitecture)\sistatus.h;$(ProjectDir)bin\$(Configuration)$(PlatformArchitecture)\sistatus.rc;$(ProjectDir)bin\$(Configuration)$(PlatformArchitecture)\sistatus_MSG00001.bin</Outputs>
      <Message>Compiling messages %(Filename)%(Extension)</Message>
    </CustomBuild>
    <None Include="bin\$(Configuration)$(PlatformArchitecture)\sistatus_MSG00001.bin" />
    <ResourceCompile Include="bin\$(Configuration)$(PlatformArchitecture)\sistatus.rc" />
    <ClInclude Include="include\kphringbuff.h" />
    <ClInclude Include="bin\$(Configuration)$(PlatformArchitecture)\sistatus.h" />
  </ItemGroup>
