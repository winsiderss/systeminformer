  DESC = Running CMake cache editor...
  pool = console
  restat = 1

build plugins\ToolStatus\edit_cache: phony plugins\ToolStatus\CMakeFiles\edit_cache.util


#############################################
# Utility command for rebuild_cache

build plugins\ToolStatus\CMakeFiles\rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D A:\systeminformer\release-clang-msvc-32\plugins\ToolStatus && "C:\Program Files\CMake\bin\cmake.exe" --regenerate-during-build -SA:\systeminformer -BA:\systeminformer\release-clang-msvc-32"
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build plugins\ToolStatus\rebuild_cache: phony plugins\ToolStatus\CMakeFiles\rebuild_cache.util

