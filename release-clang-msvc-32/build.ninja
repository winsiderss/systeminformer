  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D A:\systeminformer\release-clang-msvc-32\tools\thirdparty && "C:\Program Files\CMake\bin\cmake.exe" --regenerate-during-build -SA:\systeminformer -BA:\systeminformer\release-clang-msvc-32"
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build tools\thirdparty\rebuild_cache: phony tools\thirdparty\CMakeFiles\rebuild_cache.util

# =============================================================================
# Write statements declared in CMakeLists.txt:
# A:/systeminformer/tools/CMakeLists.txt
# =============================================================================

# =============================================================================
# Object build statements for EXECUTABLE target peview


#############################################
# Order-only phony target for peview

