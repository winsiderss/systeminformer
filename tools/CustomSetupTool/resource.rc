    LTEXT           "",IDC_STATUS,148,78,240,42
    LTEXT           "Click Finish to exit Setup.",IDC_STATIC,148,130,240,14
END

IDD_UNINSTALL DIALOGEX 0, 0, 408, 234
STYLE DS_SETFONT | WS_CHILD | WS_DISABLED | WS_CAPTION
