                    <Item Name="CONTEXT_PERF_ITEM [{i}]">*((CONTEXT_PERF_ITEM *)Items[i])</Item>
                    <Exec>i = i + 1</Exec>
                </Loop>
            </CustomListItems> -->
        </Expand>
    </Type>

</AutoVisualizer>